<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".presentation.closet.ClothRegisterFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
    
            <ImageView
                android:id="@+id/btn_select_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/btn_select_photo"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <FrameLayout
                android:id="@+id/fl_cloth"
                android:layout_width="260dp"
                android:layout_height="320dp"
                android:background="@drawable/background_radius_green"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toBottomOf="@id/btn_select_photo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageView
                    android:id="@+id/iv_cloth"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
            </FrameLayout>

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/category_container"
                android:layout_width="380dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fl_cloth"
                app:flexWrap="wrap"
                app:justifyContent="flex_start"
                app:alignItems="center"
                app:alignContent="flex_start"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp">
                <TextView
                    android:id="@+id/btnTop"
                    style="@style/CategoryButtonStyle"
                    android:text="상의" />
                <TextView
                    android:id="@+id/btnBottom"
                    style="@style/CategoryButtonStyle"
                    android:text="하의" />
                <TextView
                    android:id="@+id/btnOuter"
                    style="@style/CategoryButtonStyle"
                    android:text="아우터" />
                <TextView
                    android:id="@+id/btnShoes"
                    style="@style/CategoryButtonStyle"
                    android:text="신발" />
                <TextView
                    android:id="@+id/btnBag"
                    style="@style/CategoryButtonStyle"
                    android:text="가방" />
                <TextView
                    android:id="@+id/btnHat"
                    style="@style/CategoryButtonStyle"
                    android:text="모자" />
                <TextView
                    android:id="@+id/btnEtc"
                    style="@style/CategoryButtonStyle"
                    android:text="기타" />
            </com.google.android.flexbox.FlexboxLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:src="@drawable/btn_back2"/>
                <ImageView
                    android:id="@+id/btn_next"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:src="@drawable/btn_next"/>
            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>