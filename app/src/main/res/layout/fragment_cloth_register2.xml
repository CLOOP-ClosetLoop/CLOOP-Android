<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".ui.closet.ClothRegisterFragment2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="94dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="카테고리"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/primary_2"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="@id/et_category"/>
            <EditText
                android:id="@+id/et_category"
                android:layout_width="320dp"
                android:layout_height="50dp"
                android:hint="선택한 카테고리"
                android:textSize="16sp"
                android:textColorHint="#828892"
                android:textColor="@color/black"
                android:paddingStart="15dp"
                android:background="@drawable/background_radius_green"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tv_category"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="옷 이름"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/primary_2"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@id/et_category"
                app:layout_constraintLeft_toLeftOf="@id/et_name"/>
            <EditText
                android:id="@+id/et_name"
                android:layout_width="320dp"
                android:layout_height="50dp"
                android:hint="옷 이름을 입력해주세요."
                android:textSize="16sp"
                android:textColorHint="#828892"
                android:textColor="@color/black"
                android:paddingStart="15dp"
                android:background="@drawable/background_radius_green"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tv_name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="구매 시기"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/primary_2"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@+id/et_name"
                app:layout_constraintLeft_toLeftOf="@id/et_date"/>
            <EditText
                android:id="@+id/et_date"
                android:layout_width="320dp"
                android:layout_height="50dp"
                android:hint="YYYY / MM"
                android:textSize="16sp"
                android:textColorHint="#828892"
                android:textColor="@color/black"
                android:paddingStart="15dp"
                android:background="@drawable/background_radius_green"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="10dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tv_date"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="브랜드"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/primary_2"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@id/et_date"
                app:layout_constraintLeft_toLeftOf="@id/brand"/>
            <EditText
                android:id="@+id/brand"
                android:layout_width="320dp"
                android:layout_height="50dp"
                android:hint="브랜드룰 입력해주세요."
                android:textSize="16sp"
                android:textColorHint="#828892"
                android:textColor="@color/black"
                android:paddingStart="15dp"
                android:background="@drawable/background_radius_green"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tv_brand"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="색상"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/primary_2"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@id/brand"
                app:layout_constraintLeft_toLeftOf="@id/et_color"/>
            <EditText
                android:id="@+id/et_color"
                android:layout_width="320dp"
                android:layout_height="50dp"
                android:hint="색상을 입력해주세요."
                android:textSize="16sp"
                android:textColorHint="#828892"
                android:textColor="@color/black"
                android:paddingStart="15dp"
                android:background="@drawable/background_radius_green"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tv_color"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_season"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="계절"
                android:fontFamily="@font/pretendard"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/primary_2"
                android:layout_marginTop="30dp"
                app:layout_constraintTop_toBottomOf="@id/et_color"
                app:layout_constraintLeft_toLeftOf="@id/et_color"/>
            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/category_container"
                android:layout_width="380dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_season"
                app:flexWrap="wrap"
                app:justifyContent="flex_start"
                app:alignItems="center"
                app:alignContent="flex_start"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp">
                <TextView
                    android:id="@+id/btn_summer"
                    style="@style/CategoryButtonStyle"
                    android:text="여름" />
                <TextView
                    android:id="@+id/btn_winter"
                    style="@style/CategoryButtonStyle"
                    android:text="겨울" />
            </com.google.android.flexbox.FlexboxLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/white"
        android:layout_gravity="bottom">
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/btn_back2" />
        <ImageView
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/btn_register2" />
    </LinearLayout>
</FrameLayout>